# Example environment variables for LocalHub
# Copy this to .env and fill values (DO NOT COMMIT real secrets)

# OpenAI settings
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Database (example sqlite or full DB URL)
DATABASE_URL=sqlite:///./Backend/localhub.db

# Server
HOST=127.0.0.1
PORT=8000
DEBUG=false

# Frontend / CORS
# Comma-separated allowed origins for CORS. Add your Netlify site here:
# e.g. ALLOWED_ORIGINS=https://ai-pjt.netlify.app,http://localhost:5501
ALLOWED_ORIGINS=https://ai-pjt.netlify.app

# If frontend is deployed separately, set its base URL here (used by front-end build)
API_BASE_URL=https://ai-pjt.netlify.app

# Logging
LOG_LEVEL=info

# App secrets
SECRET_KEY=
